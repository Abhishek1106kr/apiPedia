{
  "name": "apipedia-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for apiPedia frontend and backend",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install && npm run pip-install --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:django": "npm run dev:django --workspace=backend",
    "dev:fastapi": "npm run dev:fastapi --workspace=backend",
    "dev": "concurrently --kill-others --names \"frontend,backend\" -c \"cyan,magenta\" \"npm run dev:frontend\" \"npm run dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
