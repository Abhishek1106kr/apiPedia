DATABASE_URL="postgresql://apipedia:apipedia@localhost:5434/apipedia?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=4000
HOST="0.0.0.0"

# Comma-separated list of origins allowed to call this API cross-origin.
# Defaults to the frontend's local dev server.
CORS_ORIGIN="http://localhost:3000"

# Groq (OpenAI-compatible) — used by src/modules/ai for endpoint explanations.
# Get a key at https://console.groq.com. Never commit a real value here.
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Shared bearer token guarding moderation actions (contribution
# approve/reject/rollback) and the manual monitoring trigger. This is a
# stopgap, not a real auth system — see src/plugins/auth.ts. Generate one
# with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_TOKEN=""
