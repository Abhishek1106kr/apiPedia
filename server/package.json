{
  "name": "@apipedia/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "ingest": "tsx src/ingestion/cli.ts",
    "ingest:worker": "tsx src/ingestion/queue/worker.ts",
    "monitor:worker": "tsx src/modules/monitoring/worker.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:validate": "prisma validate"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/sensible": "^6.0.2",
    "@prisma/adapter-pg": "^6.1.0",
    "@prisma/client": "^6.1.0",
    "bullmq": "^5.34.5",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "js-yaml": "^4.1.0",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22",
    "@types/pg": "^8.11.10",
    "eslint": "^9",
    "typescript-eslint": "^8.18.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.28.1": true,
    "prisma@6.19.3": true
  }
}
